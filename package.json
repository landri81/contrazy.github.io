{
  "name": "contrazy-main",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "dotenv -e .env.local -- node scripts/run-prisma-command.mjs generate",
    "prisma:migrate:deploy": "dotenv -e .env.local -- node scripts/run-prisma-command.mjs migrate deploy",
    "prisma:migrate:dev": "dotenv -e .env.local -- node scripts/run-prisma-command.mjs migrate dev",
    "prisma:push": "dotenv -e .env.local -- node scripts/run-prisma-command.mjs db push",
    "prisma:studio": "dotenv -e .env.local -- node scripts/run-prisma-command.mjs studio",
    "ensure-super-admin": "dotenv -e .env.local -- node scripts/ensure-super-admin.mjs",
    "db:setup": "dotenv -e .env.local -- node scripts/db-setup.mjs",
    "db:clear": "dotenv -e .env.local -- node scripts/clear-db.mjs",
    "db:studio": "dotenv -e .env.local -- node scripts/db-studio.mjs",
    "stripe:setup-plans": "dotenv -e .env.local -- node scripts/stripe-setup-plans.mjs",
    "stripe:listen-account-webhook": "stripe listen --forward-to http://localhost:3000/api/webhooks/stripe-account",
    "e2e:env": "node scripts/setup-e2e-env.mjs",
    "prisma:migrate:deploy:test": "dotenv -e .env.test.local -- node scripts/run-prisma-command.mjs migrate deploy",
    "e2e:seed": "dotenv -e .env.test.local -- node scripts/seed-e2e.mjs",
    "e2e:prepare": "npm run e2e:env && npm run prisma:migrate:deploy:test && npm run e2e:seed",
    "test:e2e": "dotenv -e .env.test.local -- playwright test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^6.16.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@stripe/connect-js": "^3.3.39",
    "@stripe/react-connect-js": "^3.3.36",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/qrcode.react": "^1.0.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "es-abstract": "^1.24.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "prisma": "^6.16.2",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-phone-number-input": "^3.4.16",
    "react-redux": "^9.2.0",
    "resend": "^6.12.2",
    "shadcn": "^4.6.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "typescript": "5.9.3"
  }
}
