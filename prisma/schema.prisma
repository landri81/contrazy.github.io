generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VENDOR
  CLIENT
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum StripeConnectionStatus {
  NOT_CONNECTED
  PENDING
  CONNECTED
  ERROR
}

enum TransactionKind {
  PAYMENT
  DEPOSIT
  HYBRID
}

enum TransactionStatus {
  DRAFT
  LINK_SENT
  CUSTOMER_STARTED
  DOCS_SUBMITTED
  KYC_VERIFIED
  CONTRACT_GENERATED
  SIGNED
  PAYMENT_AUTHORIZED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum RequirementType {
  DOCUMENT
  PHOTO
  TEXT
}

enum KycStatus {
  NOT_REQUIRED
  PENDING
  VERIFIED
  FAILED
}

enum SignatureStatus {
  PENDING
  SIGNED
  EXPIRED
}

enum PaymentKind {
  SERVICE_PAYMENT
  DEPOSIT_AUTHORIZATION
  DEPOSIT_CAPTURE
  DEPOSIT_RELEASE
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  SUCCEEDED
  CAPTURED
  RELEASED
  FAILED
  CANCELLED
}

enum TransactionLinkStatus {
  ACTIVE
  PROCESSING
  COMPLETED
  CANCELLED
}

enum TransactionLinkActor {
  VENDOR
  CLIENT
  ADMIN
  SYSTEM
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  LOST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum AuditActorType {
  SYSTEM
  USER
  SUPER_ADMIN
}

enum TransactionEventType {
  LINK_CREATED
  LINK_OPENED
  LINK_UPDATED
  LINK_CANCELLED
  PROFILE_SUBMITTED
  DOCUMENTS_SUBMITTED
  KYC_STARTED
  KYC_VERIFIED
  KYC_FAILED
  CONTRACT_REVIEWED
  SIGNATURE_COMPLETED
  PAYMENT_SESSION_CREATED
  SERVICE_PAYMENT_SUCCEEDED
  DEPOSIT_AUTHORIZED
  DEPOSIT_CAPTURED
  DEPOSIT_RELEASED
  DISPUTE_OPENED
  TRANSACTION_CANCELLED
  COMPLETED
  EMAIL_SENT
  WEBHOOK_PROCESSED
}

model User {
  id               String               @id @default(cuid())
  name             String?
  email            String               @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             UserRole             @default(VENDOR)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  accounts         Account[]
  sessions         Session[]
  vendorProfile    VendorProfile?
  clientProfiles   ClientProfile[]      @relation("ClientAccountProfiles")
  sentInvitations  Invitation[]         @relation("InvitationInviter")
  auditLogs        AuditLog[]           @relation("AuditActor")
  passwordResets   PasswordResetToken[]
}

model VendorProfile {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  businessName           String?
  businessSlug           String?                @unique
  businessEmail          String?
  supportEmail           String?
  businessPhone          String?
  businessAddress        String?
  businessCountry        String?
  stripeAccountId        String?
  stripeConnectionStatus StripeConnectionStatus @default(NOT_CONNECTED)
  reviewStatus           VendorStatus           @default(PENDING)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients                ClientProfile[]
  contractTemplates      ContractTemplate[]
  checklistTemplates     ChecklistTemplate[]
  transactions           Transaction[]
  invitations            Invitation[]
  webhookEvents          WebhookEvent[]
}

model ClientProfile {
  id          String          @id @default(cuid())
  userId      String?
  vendorId    String?
  fullName    String
  email       String
  phone       String?
  companyName String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User?           @relation("ClientAccountProfiles", fields: [userId], references: [id], onDelete: SetNull)
  vendor      VendorProfile?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  documents   DocumentAsset[]
}

model ContractTemplate {
  id          String        @id @default(cuid())
  vendorId    String
  name        String
  description String?
  content     String        @db.Text
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  vendor      VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model ChecklistTemplate {
  id           String          @id @default(cuid())
  vendorId     String
  name         String
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vendor       VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items        ChecklistItem[]
  transactions Transaction[]
}

model ChecklistItem {
  id          String           @id @default(cuid())
  templateId  String
  label       String
  description String?
  type        RequirementType  @default(DOCUMENT)
  required    Boolean          @default(true)
  sortOrder   Int              @default(0)
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                 String             @id @default(cuid())
  vendorId           String
  clientProfileId    String?
  contractTemplateId String?
  checklistTemplateId String?
  reference          String             @unique
  title              String
  kind               TransactionKind    @default(HYBRID)
  status             TransactionStatus  @default(DRAFT)
  currency           String             @default("EUR")
  amount             Int?
  depositAmount      Int?
  requiresKyc        Boolean            @default(false)
  stripePaymentIntentId String?
  notes              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  vendor             VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  clientProfile      ClientProfile?     @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  contractTemplate   ContractTemplate?  @relation(fields: [contractTemplateId], references: [id], onDelete: SetNull)
  checklistTemplate  ChecklistTemplate? @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  link               TransactionLink?
  requirements       TransactionRequirement[]
  documents          DocumentAsset[]
  kycVerification    KycVerification?
  signatureRecord    SignatureRecord?
  payments           Payment[]
  depositAuthorization DepositAuthorization?
  dispute            Dispute?
  events             TransactionEvent[]
  webhookEvents      WebhookEvent[]

  @@index([vendorId, createdAt])
  @@index([status])
}

model TransactionLink {
  id            String      @id @default(cuid())
  transactionId String      @unique
  token         String      @unique
  shortCode     String?     @unique
  qrCodeSvg     String?     @db.Text
  status        TransactionLinkStatus @default(ACTIVE)
  expiresAt     DateTime?
  openedAt      DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?     @db.Text
  cancelledBy   TransactionLinkActor?
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model TransactionRequirement {
  id            String          @id @default(cuid())
  transactionId String
  label         String
  instructions  String?
  type          RequirementType @default(DOCUMENT)
  required      Boolean         @default(true)
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documents     DocumentAsset[]
}

model DocumentAsset {
  id              String         @id @default(cuid())
  transactionId   String
  clientProfileId String?
  requirementId   String?
  label           String
  type            RequirementType @default(DOCUMENT)
  fileName        String?
  assetUrl        String
  publicId        String?
  uploadedAt      DateTime       @default(now())
  transaction     Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  clientProfile   ClientProfile? @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  requirement     TransactionRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@unique([transactionId, requirementId])
}

model KycVerification {
  id                String     @id @default(cuid())
  transactionId     String     @unique
  provider          String     @default("Stripe Identity")
  status            KycStatus  @default(PENDING)
  providerReference String?
  summary           String?
  verifiedAt        DateTime?
  createdAt         DateTime   @default(now())
  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model SignatureRecord {
  id               String          @id @default(cuid())
  transactionId    String          @unique
  status           SignatureStatus @default(PENDING)
  signerName       String?
  signerEmail      String?
  method           String?         @default("Canvas Signature")
  signatureDataUrl String?         @db.Text
  ipAddress        String?
  signedAt         DateTime?
  createdAt        DateTime        @default(now())
  transaction      Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  transactionId   String
  kind            PaymentKind
  status          PaymentStatus @default(PENDING)
  amount          Int
  currency        String        @default("EUR")
  stripeIntentId  String?
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, kind])
}

model DepositAuthorization {
  id             String        @id @default(cuid())
  transactionId  String        @unique
  status         PaymentStatus @default(PENDING)
  amount         Int
  currency       String        @default("EUR")
  stripeIntentId String?
  authorizedAt   DateTime?
  capturedAt     DateTime?
  releasedAt     DateTime?
  transaction    Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Dispute {
  id            String        @id @default(cuid())
  transactionId String        @unique
  status        DisputeStatus @default(OPEN)
  summary       String        @db.Text
  openedAt      DateTime      @default(now())
  resolvedAt    DateTime?
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  role       UserRole
  token      String           @unique
  vendorId   String?
  inviterId  String?
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  vendor     VendorProfile?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  inviter    User?            @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: SetNull)

  @@index([email, status])
}

model AuditLog {
  id         String         @id @default(cuid())
  actorId    String?
  actorType  AuditActorType @default(USER)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime       @default(now())
  actor      User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
}

model WebhookEvent {
  id              String        @id @default(cuid())
  vendorId        String?
  transactionId   String?
  provider        String
  providerEventId String?
  eventType       String
  status          WebhookStatus @default(RECEIVED)
  error           String?       @db.Text
  payload         Json?
  createdAt       DateTime      @default(now())
  vendor          VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  transaction     Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([provider, eventType])
  @@index([vendorId, createdAt])
  @@index([transactionId])
  @@index([status, createdAt])
  @@unique([provider, providerEventId])
}

model TransactionEvent {
  id          String               @id @default(cuid())
  transactionId String
  type        TransactionEventType
  dedupeKey   String?              @unique
  title       String
  detail      String?
  metadata    Json?
  occurredAt  DateTime             @default(now())
  createdAt   DateTime             @default(now())
  transaction Transaction          @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, occurredAt])
  @@index([type])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
